        "index": 8,
        "role": "bot",
        "time": "2025-09-14T00:21:39.930000Z",
        "message": "You started by typing in the search bar. What exactly were you searching for that time? And what made you pick Instagram over Google for that question?"
      },
      {
        "callId": "c4a994d3708848b9be794a168",
        "index": 9,
        "role": "user",
        "time": "2025-09-14T00:21:50.240000Z",
        "message": "It was more of a family problem."
