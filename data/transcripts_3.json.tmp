      {
        "callId": "3b300624332347119eddf2a07",
        "index": 54,
        "role": "bot",
        "time": "2025-09-13T23:33:07.206000Z",
        "message": "Interesting. So your searching has picked up. Can you remember what sort of things triggered you, uh, to start searching online? More often recently? Anything stand out, like, changes"
      },
