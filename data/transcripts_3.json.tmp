        "role": "bot",
        "time": "2025-09-13T23:33:48.339000Z",
        "message": "What would you like about that experience?"
      },
      {
        "callId": "dc99716bcb914182bc377a0d1",
        "index": 49,
        "role": "user",
        "time": "2025-09-13T23:33:53.359000Z",
        "message": "It's more personable."
