        "callId": "5d026cb9e89640c0b18dee95d",
        "index": 22,
        "role": "bot",
        "time": "2025-09-14T00:22:41.570000Z",
        "message": "Sounds like your process works well for you most times. If for some reason Google doesn't give you what you need, what do you typically do next?"
      },
      {
        "callId": "5d026cb9e89640c0b18dee95d",
        "index": 23,
        "role": "user",
