      {
        "callId": "6cb2d1aceb514b33a5b1f44d4",
        "index": 60,
        "role": "bot",
        "time": "2025-09-13T23:33:45.013000Z",
        "message": "Thanks for being clear. Before we wrap up, when you talk to friends or hear people recommending ways to look things up online, does anyone ever mention tools besides Google? Or is Google still what you hear the most?"
      },
      {
        "callId": "6cb2d1aceb514b33a5b1f44d4",
