        "index": 42,
        "role": "bot",
        "time": "2025-09-14T00:25:18.796000Z",
        "message": "Has anything about your habits or which tools you reach for changed in the past year or have you mainly stuck with, uh, Google out of routine?"
      },
      {
        "callId": "5d148ddb304546e0821c5791c",
        "index": 43,
