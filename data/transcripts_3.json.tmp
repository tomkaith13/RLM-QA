      {
        "callId": "fc4076e3f5eb40f79f4a86a02",
        "index": 2,
        "role": "bot",
        "time": "2025-09-14T00:08:34.797000Z",
        "message": "Glad to hear it. When you need answers online, say you're trying to figure out a recipe, tech help, or random trivia, what's the very first thing you usually do?"
      },
      {
        "callId": "fc4076e3f5eb40f79f4a86a02",
        "index": 3,
        "role": "user",
        "time": "2025-09-14T00:08:45.017000Z",
        "message": "I'll go to Google and then I'll use share"
