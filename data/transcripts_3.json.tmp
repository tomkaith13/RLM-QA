        "callId": "5d148ddb304546e0821c5791c",
        "index": 40,
        "role": "bot",
        "time": "2025-09-14T00:25:13.456000Z",
        "message": "Makes sense. For you, they're mostly just ways to get answers. A big difference between them."
      },
      {
        "callId": "5d148ddb304546e0821c5791c",
        "index": 41,
        "role": "user",
        "time": "2025-09-14T00:25:18.106000Z",
        "message": "Yeah."
