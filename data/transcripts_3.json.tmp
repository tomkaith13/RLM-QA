      {
        "callId": "b8bb08f853694679af00c66be",
        "index": 7,
        "role": "user",
        "time": "2025-09-13T23:57:58.828000Z",
        "message": "I clicked on something"
      },
      {
        "callId": "b8bb08f853694679af00c66be",
        "index": 8,
        "role": "bot",
        "time": "2025-09-13T23:58:03.988000Z",
        "message": "What made you choose that particular result to click on? Was it the title, description, the website name, or something else?"
