        "callId": "6cb2d1aceb514b33a5b1f44d4",
        "index": 58,
        "role": "bot",
        "time": "2025-09-13T23:33:29.463000Z",
        "message": "No problem. Let's shift back to habits a bit. Thinking about the past year, do you feel like you've changed how or where you search for answers online, or does it pretty much stay the same for you?"
      },
      {
        "callId": "6cb2d1aceb514b33a5b1f44d4",
        "index": 59,
        "role": "user",
        "time": "2025-09-13T23:33:40.152000Z",
        "message": "It stays the same for me."
