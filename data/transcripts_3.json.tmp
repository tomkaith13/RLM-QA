        "callId": "98cfee3f3e6949e2a599fd062",
        "index": 29,
        "role": "user",
        "time": "2025-09-14T00:12:52.765000Z",
        "message": "Sometimes it don't always be right, but for this thing I was doing at the moment, it worked perfectly."
