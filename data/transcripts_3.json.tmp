      {
        "callId": "b42ec48c40544adb94a74a62d",
        "index": 37,
        "role": "user",
        "time": "2025-09-13T22:42:35.268000Z",
        "message": "This is, uh, like I said, new and different and exciting for me. It's I feel like I'm talking to a real person even though I know I'm not. So I'm enjoying the whole thing."
      },
      {
        "callId": "b42ec48c40544adb94a74a62d",
        "index": 38,
        "role": "bot",
        "time": "2025-09-13T22:42:49.028000Z",
        "message": "Thank you for calling."
