      },
      {
        "callId": "c697c50c893f4f45b70c28589",
        "index": 40,
        "role": "bot",
        "time": "2025-09-14T01:06:42.664000Z",
        "message": "Totally fair. How about just Google versus ChatGPT then? If each were a person at a party, who are they and how would they behave?"
