      {
        "callId": "98cfee3f3e6949e2a599fd062",
        "index": 12,
        "role": "bot",
        "time": "2025-09-14T00:10:15.125000Z",
        "message": "Thanks for sharing. When Thanks for sharing. You mentioned Google and ChatGPT. If you think about the last time you needed a quick answer, which 1 did you reach for first? What made you choose that 1? Feel free to ask me any questions."
      },
      {
        "callId": "98cfee3f3e6949e2a599fd062",
