      {
        "callId": "8a4297f8fa7e4fe68b8cfb2e9",
        "index": 1,
        "role": "user",
        "time": "2025-09-14T00:08:20.052000Z",
        "message": "Varing pretty well."
      },
      {
        "callId": "8a4297f8fa7e4fe68b8cfb2e9",
        "index": 2,
        "role": "bot",
        "time": "2025-09-14T00:08:23.892000Z",
        "message": "Glad to hear it. Let's start off simple. When you need answers to something online, a quick fact, with the task, or just general info, what's the first thing you usually do?"
      },
      {
        "callId": "8a4297f8fa7e4fe68b8cfb2e9",
        "index": 3,
        "role": "user",
        "time": "2025-09-14T00:08:35.102000Z",
        "message": "I used usually go to chat GPT. Just to get the information"
