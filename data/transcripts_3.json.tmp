      {
        "callId": "b8bb08f853694679af00c66be",
        "index": 6,
        "role": "bot",
        "time": "2025-09-13T23:57:47.868000Z",
        "message": "Thanks for walking me through that. After you gave your voice input, what happened next? Did you scan the results? Click on something specific, or use 1 of the suggested summaries?"
