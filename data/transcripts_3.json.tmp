        "callId": "8cb7f8d3802644cbae2e32fff",
        "index": 26,
        "role": "bot",
        "time": "2025-09-13T22:36:06.289000Z",
        "message": "That's really clear. Um, so you you you used voice instead of typing. Just holding down the button"
