        "callId": "d53766c2a7174fc1b0119ec6c",
        "index": 30,
        "role": "bot",
        "time": "2025-09-14T00:13:05.270000Z",
        "message": "Thanks. Thinking about brand or personality, if Seres were a person at a party, who would they be, and how would they act?"
