      {
        "callId": "4c293f44d4774b8d817a7cedf",
        "index": 40,
        "role": "bot",
        "time": "2025-09-14T00:17:53.703000Z",
        "message": "You So you switched for something specific. Can you tell me the story about about that time? What were you looking for? Which engine or tool did you use? And what made you pick that 1 instead of glucocortone?"
