        "time": "2025-09-13T23:31:00.806000Z",
        "message": "About the same."
      },
      {
        "callId": "3b300624332347119eddf2a07",
        "index": 38,
        "role": "bot",
        "time": "2025-09-13T23:31:03.856000Z",
        "message": "That's clear."
      },
      {
        "callId": "3b300624332347119eddf2a07",
